            <div class="hex-subtitle-text">Pages as compact snapshots.</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Row 2 (offset) -->
    <div class="hex-row">
      <div class="hex-tile" role="listitem" data-tile="network">
        <div class="hex-tile-border"></div>
        <div class="hex-tile-fill">
          <img class="hex-tile-icon" src="/images/leapfrog-icons/network-intelligence.png" alt="" loading="eager">
          <div class="hex-content">
            <div class="hex-title">Network Intelligence</div>
            <div class="hex-subtitle-text">See what the page is really doing.</div>
          </div>
        </div>
      </div>
      <div class="hex-tile" role="listitem" data-tile="selfimprove">
        <div class="hex-tile-border"></div>
        <div class="hex-tile-fill">
          <img class="hex-tile-icon" src="/images/leapfrog-icons/self-improvement.png" alt="" loading="eager">
          <div class="hex-content">
            <div class="hex-title">Self-Improvement</div>
            <div class="hex-subtitle-text">Learns from every visit.</div>
          </div>
        </div>
      </div>
      <div class="hex-tile" role="listitem" data-tile="interaction">
        <div class="hex-tile-border"></div>
        <div class="hex-tile-fill">
          <img class="hex-tile-icon" src="/images/leapfrog-icons/interaction.png" alt="" loading="eager">
          <div class="hex-content">
            <div class="hex-title">Interaction</div>
            <div class="hex-subtitle-text">One tool. Every action.</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Row 3 -->
    <div class="hex-row">
      <div class="hex-tile" role="listitem" data-tile="tiling">
        <div class="hex-tile-border"></div>
