<!-- ══════════════════════════════════════ SCRIPTS ══════════════════════════════════════ -->
<script is:inline>
  // Scroll-triggered reveals (per-element)
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));

  // Stat counter animation with easing
  const statObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const stats = entry.target.querySelectorAll('.stat');
        stats.forEach(stat => {
          const target = parseInt(stat.dataset.count);
          const numEl = stat.querySelector('.stat-number');
          const suffix = target === 5 ? 'x' : '';
          const duration = 1500;
          const start = performance.now();
          const animate = (now) => {
            const elapsed = now - start;
            const t = Math.min(elapsed / duration, 1);
            const eased = 1 - Math.pow(1 - t, 3); // ease-out cubic
            const current = Math.round(target * eased);
            numEl.textContent = current + suffix;
            if (t < 1) {
              requestAnimationFrame(animate);
            } else {
              numEl.textContent = target + suffix;
              numEl.style.animation = 'phosphorFlare 0.6s ease-out forwards';
            }
          };
          requestAnimationFrame(animate);
        });
        statObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.5 });
  statObserver.observe(document.getElementById('stats'));

  // Frog blink animation (8s interval with double-blink)
  function blinkFrog() {
    document.querySelectorAll('.frog-eyes, .frog-eyes-lg').forEach(el => {
      el.style.opacity = '0.1';
      setTimeout(() => { el.style.opacity = '1'; }, 150);
      setTimeout(() => { el.style.opacity = '0.1'; }, 300);
      setTimeout(() => { el.style.opacity = '1'; }, 450);
    });
  }
  setInterval(blinkFrog, 8000);

  // Watermark blink (the @ symbols are the eyes)
  function blinkWatermark() {
    document.querySelectorAll('.watermark-at').forEach(el => {
      el.style.opacity = '0';
      setTimeout(() => { el.style.opacity = '1'; }, 150);
      setTimeout(() => { el.style.opacity = '0'; }, 300);
      setTimeout(() => { el.style.opacity = '1'; }, 450);
    });
  }
  setTimeout(() => setInterval(blinkWatermark, 8000), Math.random() * 4000);

  // Fade-in on load
  document.querySelectorAll('.fade-in').forEach(el => {
    const delay = getComputedStyle(el).getPropertyValue('--delay') || '0s';
    el.style.animationDelay = delay;
  });

  // Nav background on scroll
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('nav-scrolled', window.scrollY > 50);
  });

  // Safety: reveal all after 2s
  setTimeout(() => {
    document.querySelectorAll('.scroll-reveal').forEach(el => {
      if (!el.classList.contains('revealed')) el.classList.add('revealed');
    });
    document.querySelectorAll('.stat').forEach(stat => {
      const target = parseInt(stat.dataset.count);
      const numEl = stat.querySelector('.stat-number');
      if (numEl && numEl.textContent === '0' && target > 0) {
        const suffix = target === 5 ? 'x' : '';
        numEl.textContent = target + suffix;
      }
    });
  }, 2000);

  // ── HEX GRID: Ripple Canvas ──────────────────────────────────
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  (function() {
    if (prefersReducedMotion) return;
    const canvas = document.getElementById('ripple-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let W, H;
    const ripples = [];

    function resize() {
      const section = document.getElementById('pondSection');
      if (!section) return;
      W = canvas.width = section.offsetWidth;
      H = canvas.height = section.offsetHeight;
    }

    resize();
    window.addEventListener('resize', resize);

    let lastRipple = 0;
    const pondSection = document.getElementById('pondSection');
    if (pondSection) {
      pondSection.addEventListener('mousemove', (e) => {
        const now = Date.now();
        if (now - lastRipple < 100) return;
        lastRipple = now;

        const rect = canvas.getBoundingClientRect();
        ripples.push({
          x: e.clientX - rect.left,
          y: e.clientY - rect.top,
          r: 0,
          maxR: 140 + Math.random() * 80,
          alpha: 0.3,
          speed: 1.0 + Math.random() * 0.6
        });

        if (ripples.length > 30) ripples.shift();
      });
    }

    function tick() {
      ctx.clearRect(0, 0, W, H);

      for (let i = ripples.length - 1; i >= 0; i--) {
        const rip = ripples[i];
        rip.r += rip.speed;
        rip.alpha *= 0.983;

        if (rip.alpha < 0.004 || rip.r > rip.maxR) {
          ripples.splice(i, 1);
          continue;
        }

        for (let ring = 0; ring < 3; ring++) {
          const radius = rip.r - ring * 14;
          if (radius <= 0) continue;

          ctx.beginPath();
          ctx.arc(rip.x, rip.y, radius, 0, Math.PI * 2);
          ctx.strokeStyle = 'rgba(0, 255, 65, ' + (rip.alpha * (1 - ring * 0.3)) + ')';
          ctx.lineWidth = 1.0 - ring * 0.25;
          ctx.stroke();
        }
      }

      requestAnimationFrame(tick);
    }

    tick();
  })();

  // ── HEX GRID: Particle Canvas ──────────────────────────────────
  (function() {
    if (prefersReducedMotion) return;
    const canvas = document.getElementById('particle-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let W, H;
    const particles = [];
    const PARTICLE_COUNT = 90;

    function resize() {
      const section = document.getElementById('pondSection');
      if (!section) return;
      W = canvas.width = section.offsetWidth;
      H = canvas.height = section.offsetHeight;
    }

    resize();
    window.addEventListener('resize', resize);

    for (let i = 0; i < PARTICLE_COUNT; i++) {
      particles.push(createParticle(true));
    }

    function createParticle(randomY) {
      return {
        x: Math.random() * 3000,
        y: randomY ? Math.random() * 2000 : H + 10 + Math.random() * 100,
        vx: (Math.random() - 0.5) * 0.25,
        vy: -0.12 - Math.random() * 0.22,
        size: Math.random() < 0.15 ? (2.5 + Math.random() * 2) : (0.8 + Math.random() * 1.8),
        alpha: 0.15 + Math.random() * 0.45,
        pulse: Math.random() * Math.PI * 2,
        pulseSpeed: 0.008 + Math.random() * 0.025,
        drift: (Math.random() - 0.5) * 0.005,
        blinkChance: Math.random() < 0.08 ? 0.003 : 0
      };
    }

    function tick() {
      ctx.clearRect(0, 0, W, H);

      for (const p of particles) {
        p.x += p.vx;
        p.y += p.vy;
        p.pulse += p.pulseSpeed;
        p.vx += p.drift;

        if (Math.abs(p.vx) > 0.4) p.vx *= 0.95;

        if (p.y < -20) {
          p.y = H + 20;
          p.x = Math.random() * W;
        }
        if (p.x < -20) p.x = W + 20;
        if (p.x > W + 20) p.x = -20;

        let currentAlpha = p.alpha * (0.5 + 0.5 * Math.sin(p.pulse));

        if (p.blinkChance > 0 && Math.random() < p.blinkChance) {
          currentAlpha = Math.min(currentAlpha * 3, 0.9);
        }

        const glowRadius = p.size * 5;
        const grad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, glowRadius);
        grad.addColorStop(0, 'rgba(0, 255, 65, ' + (currentAlpha * 0.8) + ')');
        grad.addColorStop(0.25, 'rgba(0, 255, 65, ' + (currentAlpha * 0.3) + ')');
        grad.addColorStop(0.6, 'rgba(0, 255, 65, ' + (currentAlpha * 0.08) + ')');
        grad.addColorStop(1, 'rgba(0, 255, 65, 0)');

        ctx.beginPath();
        ctx.arc(p.x, p.y, glowRadius, 0, Math.PI * 2);
        ctx.fillStyle = grad;
        ctx.fill();

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size * 0.5, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(180, 255, 200, ' + Math.min(currentAlpha * 1.5, 0.95) + ')';
        ctx.fill();
      }

      requestAnimationFrame(tick);
    }

    tick();
  })();

  // ── HEX GRID: Post-animation cleanup ──────────────────────────
  document.querySelectorAll('.hex-tile').forEach(function(tile) {
    tile.addEventListener('animationend', function() {
      tile.classList.add('emerged');
    });
  });

  // ── HEX GRID: Modal ──────────────────────────────────────────
  var hexModalData = {
    sessions: {
      icon: '/images/leapfrog-icons/sessions-pool.png',
      title: 'Sessions & Pool',
      tagline: '15 isolated sessions. Zero bleed.',
      desc: 'Each session gets its own cookies, storage, fingerprint, viewport, locale, timezone, and proxy. Run up to 15 browsers in parallel from one server \u2014 they never see each other.'
    },
    profiles: {
      icon: '/images/leapfrog-icons/profiles-auth.png',
      title: 'Profiles & Auth',
      tagline: 'Stay logged in. For real.',
      desc: 'Import cookies from your actual Chrome browser. Save login state to disk and reload it next session. Sites trust you because the cookies are real.'
    },
    navigation: {
      icon: '/images/leapfrog-icons/navigation-perception.png',
      title: 'Navigation & Perception',
      tagline: 'Pages as compact snapshots.',
      desc: 'Instead of raw HTML, your agent sees a compact accessibility snapshot \u2014 @e3 button "Submit" \u2014 not thousands of tokens of nested divs. Dramatically fewer tokens per page.'
    },
    network: {
      icon: '/images/leapfrog-icons/network-intelligence.png',
      title: 'Network Intelligence',
      tagline: 'See what the page is really doing.',
      desc: 'Log every HTTP request. Block trackers. Mock responses. Discover JSON APIs automatically and classify them as data, auth, tracking, or ads. Export as OpenAPI specs.'
    },
    selfimprove: {
      icon: '/images/leapfrog-icons/self-improvement.png',
      title: 'Self-Improvement',
      tagline: 'Learns from every visit.',
      desc: 'Saves a small file per domain \u2014 working selectors, stealth levels, wait strategies, consent buttons, discovered APIs. Every visit makes the next one faster and cheaper.'
    },
    interaction: {
      icon: '/images/leapfrog-icons/interaction.png',
      title: 'Interaction',
      tagline: 'One tool. Every action.',
      desc: 'Click, fill, type, scroll, drag, upload, hover \u2014 all through one act tool. Batch up to 100 actions per call. Built-in humanized timing so sites don\u2019t flag you as a bot.'
    },
    tiling: {
      icon: '/images/leapfrog-icons/tiling-reflow.png',
      title: 'Tiling & Reflow',
      tagline: 'Windows organize themselves.',
      desc: 'Open 5 headed sessions and they auto-arrange into a grid on your screen. Close one and the rest reflow to fill the gap. Grid or master layout, multi-monitor aware, with tab tracking for popups and OAuth redirects built in.'
    },
    recording: {
      icon: '/images/leapfrog-icons/recording-replay.png',
      title: 'Recording & Replay',
      tagline: 'Record once. Replay anytime.',
      desc: 'Export your session as a replayable JSON script or a full Playwright test. Replay with variable overrides and skip-on-error. Export Playwright traces for debugging.'
    },
    capture: {
      icon: '/images/leapfrog-icons/capture-human.png',
      title: 'Capture \u00b7 Pagination \u00b7 Human',
      tagline: 'Screenshots, scrolling, and the @..@ tap-in.',
      desc: 'Take full-page screenshots. Walk paginated content automatically. When your agent hits a wall \u2014 a hard CAPTCHA, a confusing form \u2014 it shows the @..@ overlay and waits for you.'
    }
  };

  var hexModal = document.getElementById('hexModal');
  var hexModalCloseBtn = document.getElementById('hexModalClose');

  document.querySelectorAll('.hex-tile').forEach(function(tile) {
    tile.setAttribute('tabindex', '0');

    function openHexModal() {
      var key = tile.dataset.tile;
      var data = hexModalData[key];
      if (!data) return;
      document.getElementById('hexModalIcon').src = data.icon;
      document.getElementById('hexModalTitle').textContent = data.title;
      document.getElementById('hexModalTagline').textContent = data.tagline;
      document.getElementById('hexModalDesc').textContent = data.desc;
      hexModal.classList.add('active');
    }

    tile.addEventListener('click', openHexModal);
    tile.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openHexModal();
      }
    });
  });

  if (hexModalCloseBtn) {
    hexModalCloseBtn.addEventListener('click', function() { hexModal.classList.remove('active'); });
  }
  if (hexModal) {
    hexModal.addEventListener('click', function(e) {
      if (e.target === hexModal) hexModal.classList.remove('active');
    });
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && hexModal) hexModal.classList.remove('active');
  });
</script>

