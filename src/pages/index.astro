    right: 0;
    height: 30%;
    background: linear-gradient(to top, var(--lf-void), transparent);
    z-index: 1;
  }
  .visual-break-label {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    padding: 1rem 2.5rem;
    background: rgba(20, 23, 32, 0.7);
    backdrop-filter: blur(8px);
    border: var(--lf-ghost-border);
  }
  .visual-break-label span {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--lf-phosphor);
  }

  /* ── HEX GRID: POND SECTION ──────────────────────────────────── */
  .pond-section {
    position: relative;
    width: 100%;
    min-height: 100vh;
    padding: 80px 24px 120px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    background:
      radial-gradient(ellipse 80% 50% at 50% 45%, var(--lf-green-05) 0%, transparent 60%),
      radial-gradient(ellipse 40% 30% at 20% 70%, rgba(0, 255, 65, 0.02) 0%, transparent 50%),
      radial-gradient(ellipse 35% 25% at 80% 30%, rgba(0, 255, 65, 0.015) 0%, transparent 50%),
      var(--lf-void);
    --hex-size: 290px;
    --hex-h: calc(var(--hex-size) * 1.1547);
    --hex-gap: 24px;
  }

  .pond-section::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: radial-gradient(ellipse 55% 50% at 50% 50%,
      transparent 40%,
      rgba(14, 17, 24, 0.15) 70%,
      rgba(10, 12, 18, 0.35) 88%,
      rgba(6, 8, 14, 0.55) 100%
    );
    pointer-events: none;
  }

  /* Canvas layers */
  #ripple-canvas,
  #particle-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  #ripple-canvas { z-index: 2; }
  #particle-canvas { z-index: 12; }

  /* Fog layers */
  .fog-layer {
    position: absolute;
    width: 200%;
    height: 100%;
    top: 0;
    left: -50%;
    z-index: 3;
    pointer-events: none;
    opacity: 0;
    animation: fog-drift 40s ease-in-out infinite, fog-in 3s ease-out forwards;
  }
  .fog-layer--1 {
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(26, 30, 40, 0.18) 20%,
      rgba(34, 39, 51, 0.1) 40%,
      transparent 60%,
      rgba(26, 30, 40, 0.14) 80%,
      transparent 100%
    );
    top: 15%;
  }
  .fog-layer--2 {
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(34, 39, 51, 0.12) 30%,
      transparent 50%,
      rgba(26, 30, 40, 0.15) 70%,
      transparent 100%
    );
    animation-delay: -12s;
    animation-duration: 50s;
    top: 55%;
  }
  .fog-layer--3 {
    background: linear-gradient(90deg,
      transparent 10%,
      rgba(34, 39, 51, 0.08) 35%,
      rgba(26, 30, 40, 0.06) 55%,
      transparent 80%
    );
    animation-delay: -6s;
    animation-duration: 60s;
    top: 80%;
  }

  @keyframes fog-drift {
    0%   { transform: translateX(0); }
    50%  { transform: translateX(-12%); }
    100% { transform: translateX(0); }
  }
  @keyframes fog-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* Pond watermark — ghosted behind grid */
  .pond-watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 5;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 140px;
    font-weight: 500;
    color: rgba(0, 255, 65, 0.035);
    letter-spacing: 0.15em;
    pointer-events: none;
    user-select: none;
    text-shadow:
      0 0 80px rgba(0, 255, 65, 0.02),
      0 0 160px rgba(0, 255, 65, 0.01);
    animation: watermark-breathe 8s ease-in-out infinite;
  }
  @keyframes watermark-breathe {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.4; }
  }

  /* Hex section header */
  .hex-section-header {
    position: relative;
    z-index: 10;
    text-align: center;
    margin-bottom: 60px;
    opacity: 0;
    animation: hex-header-fade 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
  }
  .hex-section-header h2 {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-weight: 300;
    font-size: clamp(2rem, 4vw, 3.2rem);
    letter-spacing: 0.08em;
    color: var(--lf-text-primary);
    text-transform: uppercase;
    position: relative;
    display: inline-block;
  }
  .hex-section-header h2::after {
    content: '';
    position: absolute;
    bottom: -12px;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--lf-phosphor), transparent);
    opacity: 0.4;
  }
  .hex-subtitle-label {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.8rem;
    color: var(--lf-text-tertiary);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: 24px;
  }
  @keyframes hex-header-fade {
    from { opacity: 0; transform: translateY(-20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Honeycomb grid */
  .hex-grid {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hex-row {
    display: flex;
    gap: var(--hex-gap);
    justify-content: center;
  }
  .hex-row + .hex-row {
    margin-top: calc(var(--hex-h) * -0.25 + var(--hex-gap) * 0.5);
  }
  .hex-row:nth-child(even) {
    transform: translateX(calc(var(--hex-size) / 2 + var(--hex-gap) / 2));
  }

  /* Hex tile */
  .hex-tile {
    position: relative;
    width: var(--hex-size);
    height: var(--hex-h);
    cursor: pointer;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), filter 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    opacity: 0;
    animation: hex-emerge 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .hex-tile:nth-child(1) { animation-delay: 0.15s; }
  .hex-tile:nth-child(2) { animation-delay: 0.25s; }
  .hex-tile:nth-child(3) { animation-delay: 0.35s; }
  .hex-row:nth-child(2) .hex-tile:nth-child(1) { animation-delay: 0.35s; }
  .hex-row:nth-child(2) .hex-tile:nth-child(2) { animation-delay: 0.45s; }
  .hex-row:nth-child(2) .hex-tile:nth-child(3) { animation-delay: 0.55s; }
  .hex-row:nth-child(3) .hex-tile:nth-child(1) { animation-delay: 0.55s; }
  .hex-row:nth-child(3) .hex-tile:nth-child(2) { animation-delay: 0.65s; }
  .hex-row:nth-child(3) .hex-tile:nth-child(3) { animation-delay: 0.75s; }

  @keyframes hex-emerge {
    from {
      opacity: 0;
      transform: translateY(30px) scale(0.92);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  .hex-tile.emerged {
    opacity: 1;
    animation: none;
  }

  /* Beveled border */
  .hex-tile-border {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      rgba(0,255,65,0.55) 0%,
      rgba(0,255,65,0.35) 30%,
      rgba(0,200,50,0.15) 70%,
      rgba(0,150,30,0.08) 100%
    );
    z-index: 0;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5)) drop-shadow(0 0 8px rgba(0,255,65,0.12));
  }

  /* Inner fill */
  .hex-tile-fill {
    position: absolute;
    inset: 3px;
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    background: var(--lf-deep);
    z-index: 1;
    overflow: hidden;
  }

  /* Icon image — oversized, bleeding off edges, dimmed as atmosphere */
  .hex-tile-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(1.35);
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 2;
    opacity: 0.25;
    filter: brightness(0.7) saturate(0.6);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), filter 0.5s ease, opacity 0.5s ease;
  }

  /* Text is the hero — centered in tile */
  .hex-content {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 4;
    text-align: center;
    padding: 0 12%;
    width: 100%;
    transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .hex-title {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-weight: 700;
    font-size: 1rem;
    color: var(--lf-text-primary);
    letter-spacing: 0.02em;
    line-height: 1.25;
    text-shadow: 0 2px 16px rgba(0,0,0,0.95), 0 1px 4px rgba(0,0,0,0.7);
    margin-bottom: 6px;
  }
  .hex-subtitle-text {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.65rem;
    color: var(--lf-phosphor);
    letter-spacing: 0.03em;
    line-height: 1.35;
    text-shadow: 0 2px 12px rgba(0,0,0,0.9), 0 1px 3px rgba(0,0,0,0.6);
    opacity: 0.7;
    transition: opacity 0.4s ease, color 0.4s ease;
  }

  /* Hover states */
  .hex-grid:hover .hex-tile:not(:hover) {
    filter: brightness(0.5) saturate(0.5);
    transform: scale(0.97);
  }
  .hex-tile:hover {
    transform: scale(1.05);
    z-index: 20;
    filter: drop-shadow(0 0 24px rgba(0,255,65,0.2)) drop-shadow(0 0 60px rgba(0,255,65,0.08));
  }
  .hex-tile:hover .hex-tile-icon {
    opacity: 0.4;
    filter: brightness(0.85) saturate(0.8);
    transform: translate(-50%, -50%) scale(1.4);
  }
  .hex-tile:hover .hex-subtitle-text {
    opacity: 1;
  }
  .hex-tile:hover .hex-tile-border {
    background: linear-gradient(
      160deg,
      rgba(0,255,65,0.8) 0%,
      rgba(0,255,65,0.5) 30%,
      rgba(0,200,50,0.3) 70%,
      rgba(0,150,30,0.15) 100%
    );
    filter: drop-shadow(0 3px 6px rgba(0,0,0,0.6)) drop-shadow(0 0 16px rgba(0,255,65,0.25));
  }
  .hex-tile:hover .hex-subtitle-text {
    opacity: 1;
    color: var(--lf-phosphor);
  }
  .hex-tile:hover .hex-title {
    color: #fff;
  }

  /* ── HEX GRID: MODAL ──────────────────────────────────────────── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(10, 12, 18, 0.85);
    backdrop-filter: blur(12px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .modal-overlay.active {
    opacity: 1;
    pointer-events: all;
  }
  .hex-modal {
    background: var(--lf-surface);
    border: 2px solid rgba(0,255,65,0.25);
    max-width: 560px;
    width: 90%;
    padding: 3rem;
    position: relative;
    transform: translateY(20px) scale(0.96);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 8px 40px rgba(0,0,0,0.5), 0 0 30px rgba(0,255,65,0.06);
  }
  .modal-overlay.active .hex-modal {
    transform: translateY(0) scale(1);
  }
  .hex-modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: 1px solid rgba(255,255,255,0.15);
    color: var(--lf-text-tertiary);
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.75rem;
    padding: 0.4rem 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .hex-modal-close:hover {
    color: var(--lf-phosphor);
    border-color: rgba(0,255,65,0.3);
  }
  .hex-modal-icon {
    width: 80px;
    height: 80px;
    object-fit: contain;
    margin-bottom: 1.5rem;
  }
  .hex-modal h3 {
    font-family: var(--font-display, 'Space Grotesk', sans-serif);
    font-weight: 600;
    font-size: 1.5rem;
    color: var(--lf-text-primary);
    margin-bottom: 0.5rem;
  }
  .hex-modal-tagline {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.75rem;
    color: var(--lf-phosphor);
    letter-spacing: 0.05em;
    margin-bottom: 1.25rem;
  }
  .hex-modal p {
    font-family: var(--font-body, 'IBM Plex Sans', sans-serif);
    font-size: 0.95rem;
    color: var(--lf-text-secondary);
    line-height: 1.7;
  }

  /* ── HEX GRID: RESPONSIVE ─────────────────────────────────────── */
  @media (max-width: 1440px) {
    .pond-section {
      --hex-size: 260px;
    }
  }
  @media (max-width: 1100px) {
    .pond-section {
      --hex-size: 220px;
      --hex-gap: 18px;
    }
    .hex-title { font-size: 0.72rem; }
    .hex-subtitle-text { font-size: 0.55rem; }
  }
  @media (max-width: 768px) {
    .pond-section {
      --hex-size: 160px;
      --hex-gap: 14px;
      padding: 60px 12px 80px;
    }
    .hex-section-header h2 { font-size: 1.6rem; }
    .hex-subtitle-label { font-size: 0.65rem; }
    .pond-watermark { font-size: 60px; }
    .hex-title { font-size: 0.6rem; }
    .hex-subtitle-text { font-size: 0.48rem; }
    .hex-content { bottom: 10%; padding: 0 8%; }
  }
  @media (max-width: 600px) {
    .pond-section {
      --hex-size: 130px;
      --hex-gap: 8px;
    }
    .hex-title { font-size: 0.5rem; white-space: normal; }
    .hex-subtitle-text { font-size: 0.42rem; }
  }

  /* ── HEX GRID: REDUCED MOTION ─────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .fog-layer {
      animation: none !important;
      opacity: 1 !important;
    }
    .pond-watermark {
      animation: none !important;
      opacity: 1 !important;
    }
    .hex-tile {
      opacity: 1 !important;
      animation: none !important;
    }
    .hex-section-header {
      opacity: 1 !important;
      animation: none !important;
    }
  }

  /* ── SELF-IMPROVEMENT ────────────────────────────────────────── */
  #self-improvement {
    background:
      radial-gradient(ellipse 60% 30% at 20% 80%, rgba(0, 255, 65, 0.015) 0%, transparent 50%),
      var(--lf-void);
  }

  /* ── FLYWHEEL SPLIT LAYOUT ─────────────────────────────── */
  .flywheel-split {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 4rem;
    align-items: center;
  }

  .flywheel-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    /* let the image bleed slightly left for asymmetry */
    margin-left: -2rem;
  }
  .flywheel-hero-glow {
    position: absolute;
    inset: -25%;
    background: radial-gradient(circle at 50% 50%,
      rgba(0, 255, 65, 0.14) 0%,
      rgba(0, 255, 65, 0.05) 35%,
      transparent 65%
    );
    pointer-events: none;
    z-index: 0;
    animation: glowPulse 4s ease-in-out infinite alternate;
  }
  @keyframes glowPulse {
    0% { opacity: 0.6; transform: scale(0.95); }
    100% { opacity: 1; transform: scale(1.05); }
  }
  .flywheel-hero-img {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 420px;
    border-radius: 12px;
    filter: drop-shadow(0 0 48px rgba(0, 255, 65, 0.18));
    transition: filter 0.5s var(--ease-reveal), transform 0.5s var(--ease-reveal);
  }
  .flywheel-hero-img:hover {
    filter: drop-shadow(0 0 72px rgba(0, 255, 65, 0.3));
    transform: scale(1.03) rotate(2deg);
  }

  .flywheel-content {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .flywheel-content h2 {
    margin-bottom: 1rem;
  }

  /* Compact terminal dossier inside the right column */
  .flywheel-dossier {
    margin-top: 1.75rem;
  }
  .flywheel-evidence-caption {
    font-size: 0.75rem;
    margin-top: 0.5rem;
    font-style: italic;
    letter-spacing: 0.01em;
    color: var(--lf-text-tertiary);
  }

  /* ── FLYWHEEL CARDS (3-col grid) ─────────────────────────── */
  .flywheel-cards-heading {
    text-align: center;
    margin: 4.5rem 0 1.75rem;
    font-size: 1.375rem;
  }
  .flywheel-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin: 0 auto;
  }

  #architecture {
    background:
      radial-gradient(ellipse 50% 40% at 80% 20%, rgba(0, 255, 65, 0.01) 0%, transparent 50%),
      var(--lf-void);
  }

  .dossier { position: relative; }
  .mechanism {
    padding: 1.25rem;
    padding-left: 1.5rem;
    border-left: var(--lf-accent-border);
    background: var(--lf-deep);
    transition: background 0.2s;
  }
  .mechanism:hover { background: var(--lf-surface); }
  .mechanism-name {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    color: var(--lf-text-primary);
    margin-bottom: 0.375rem;
  }
  .mechanism-desc {
    color: var(--lf-text-secondary);
    font-size: 0.875rem;
    line-height: 1.65;
  }
  .mechanism-desc code {
    background: var(--lf-abyss);
    padding: 0.125rem 0.375rem;
    font-size: 0.8125rem;
    color: var(--lf-phosphor);
  }
  .self-improve-cta {
    text-align: center;
    margin-top: 2rem;
    padding-top: 2rem;
  }
  .self-improve-cta code {
    background: var(--lf-deep);
    padding: 0.125rem 0.4375rem;
    font-size: 0.8125rem;
    color: var(--lf-phosphor);
  }

  /* ── ARCHITECTURE DIAGRAM ────────────────────────────────────── */
  .arch-diagram {
    max-width: 800px;
    width: 100%;
    margin: 0 auto;
  }

  /* ── COMPARISON ──────────────────────────────────────────────── */
  .comparison-section {
    background: var(--lf-deep);
  }
  .table-wrap { overflow-x: auto; }

  /* ── GET STARTED ─────────────────────────────────────────────── */
  .get-started-section {
    background: var(--lf-deep);
  }
  .cta-section { max-width: 680px; text-align: center; margin: 0 auto; }
  .cta-section .code-block { text-align: left; }
  .badge-row { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; margin-top: 2rem; }
  .confidence-stamp {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6875rem;
    color: var(--lf-text-quaternary);
    letter-spacing: 0.08em;
    margin-top: 2rem;
  }

  /* ── ORIGIN ──────────────────────────────────────────────────── */
  .origin-section-wrap { padding-bottom: 4rem; }
  .origin-section { max-width: 640px; text-align: center; margin: 0 auto; }
  .origin-quote { border: none; padding: 0; margin: 0; }
  .origin-line {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 500;
    line-height: 1.6;
    color: var(--lf-text-secondary);
    margin-bottom: 0.5rem;
  }
  .origin-frog { margin-top: 3rem; }
  .frog-eyes-lg {
    font-size: 3rem;
    transition: opacity 0.15s;
    display: inline-block;
  }
  .frog-eyes { transition: opacity 0.15s; }

  /* (footer merged into dive scene) */

  /* ── DIVE SCENE (bottom video section) ────────────────────── */
  .dive-scene {
    position: relative;
    min-height: 60vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .dive-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .dive-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      var(--lf-void) 0%,
      rgba(34, 39, 51, 0.4) 25%,
      rgba(34, 39, 51, 0.3) 60%,
      rgba(20, 23, 32, 0.75) 100%
    );
    z-index: 1;
    pointer-events: none;
  }
  .dive-img-fallback {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .dive-img-fallback img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.5;
  }
  /* Hide fallback when video plays */
  .dive-bg:not([src=""]) ~ .dive-img-fallback { display: none; }
  .dive-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 6rem 0 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100%;
  }
