          <tr><td>Self-improving</td><td class="highlight">Per-domain</td><td>—</td><td>—</td><td>—</td></tr>
          <tr><td>Crash recovery</td><td class="highlight">Auto</td><td>—</td><td>—</td><td>Cloud</td></tr>
          <tr><td>Local-first</td><td class="highlight">Yes</td><td>Yes</td><td>Yes</td><td>—</td></tr>
          <tr><td>Price</td><td class="highlight">Free (MIT)</td><td>Free</td><td>Free</td><td>Paid tiers</td></tr>
